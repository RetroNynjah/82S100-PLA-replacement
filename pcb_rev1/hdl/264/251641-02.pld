PIN 19 = uport;
PIN 20 = phi2;
PIN 21 = f0;

pinnode = phi2_p;

f0 = ras # !a10 # !a11 # !a13 # a9 # !a8 # !a14 # !a12 # a7 # a6 # !a5 # a4 # !a15 # !phi0;
