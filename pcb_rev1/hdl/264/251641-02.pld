addrclk = ras # !a10 # !a11 # !a13 # a9 # !a8 # !a14 # !a12 # !a7 # !a6 # a5 # !a4 # !a15 # !phi0 # !i0;
addrclk.oe = !CE;

keyport = ras # !a10 # !a11 # !a13 # a9 # !a8 # !a14 # !a12 # a7 # a6 # !a5 # !a4 # !a15 # !phi0 # !i0;
keyport.oe = !CE;

kernal = a10 & a11 & a13 & !a9 & !a8 & a14 & a12 & a15;
kernal.oe = !CE;

f7 = phi2_p # mux;
f7.oe = !CE;

