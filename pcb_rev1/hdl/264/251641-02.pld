PIN 42 = a12;
PIN 43 = a7;
PIN 44 = a6;
PIN 2  = a5;
PIN 3  = a4;
PIN 6  = a15;
PIN 8  = phi0;
PIN 11 = i0;
PIN 23 = ras;
PIN 25 = a10;
PIN 27 = a11;
PIN 30 = a13;
PIN 33 = a9;
PIN 34 = a8;
PIN 35 = a14;
PIN 37 = mux;
PIN 22 = CE;

PIN 12 = f7;
PIN 13 = kernal;
PIN 14 = keyport;
PIN 15 = addrclk;
